# Copy this file to .env and fill in your values.

# Gemini (Google AI Studio) API key — get one at https://aistudio.google.com/apikey
# Alternative env names if you already use them elsewhere:
# GOOGLE_API_KEY or (legacy) VERTEX_API_KEY
GEMINI_API_KEY=your_api_key_here

# Default model (see https://ai.google.dev/gemini-api/docs/models)
# GEMINI_MODEL=gemini-2.5-flash

# Comma-separated browser origins for CORS. Use your real site in production (not *).
# CORS_ORIGINS=https://www.permiasnasional.com,https://permiasnasional.com

# Behind nginx/caddy: trust X-Forwarded-For so per-IP rate limits use the real client.
# TRUST_X_FORWARDED_FOR=1

# Throttle expensive Gemini calls per IP (Flask-Limiter). Example: 30 per minute, 2 per second
# CHAT_RATE_LIMIT=20 per minute

# Shared rate-limit store for multiple gunicorn workers (default: in-memory)
# RATELIMIT_STORAGE_URI=redis://127.0.0.1:6379

# Reject very large JSON bodies to /api/... (bytes)
# MAX_REQUEST_BYTES=65536

# Flask
FLASK_DEBUG=false
PORT=5001