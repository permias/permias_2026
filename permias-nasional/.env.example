# Public API origin for the chat (no trailing slash). Leave empty when the site
# and API share the same host (e.g. nginx proxies /api to the Flask app).
# Example for a separate API host: VITE_API_BASE=https://api.example.com
# Never put Gemini/API secrets here: VITE_* is exposed in the built site JS.
VITE_API_BASE=
